# The Validity of LLM Trait Prediction in a Recruitment Context - Plots

# This script creates plots based on the results from my dissertations statistical analyses

# Loading necessary libraries

library(tidyverse)
library(ggplot2)
library(patchwork)   # combining plots into panels
library(fmsb)        # radar chart

# Load processed data
# Update the filename/path to match your local file lcoation

df <- read_csv("C:\\Users\\Lewis\\Documents\\scored_standardised_data.csv")

traits     <- c("Extraversion", "Agreeableness", "Conscientiousness",
                "Neuroticism", "Openness")
trait_cols <- setNames(
  c("#4E79A7", "#F28E2B", "#E15759", "#76B7B2", "#59A14F"),
  traits
)

# Shared theme across plots for a more sophisticated look

dissertation_theme <- theme_classic(base_size = 12) +
  theme(
    strip.background  = element_blank(),
    strip.text        = element_text(face = "bold", size = 11),
    legend.position   = "bottom",
    plot.title        = element_text(face = "bold", size = 13),
    plot.subtitle     = element_text(size = 10, colour = "grey40"),
    axis.title        = element_text(size = 11),
    panel.grid.major  = element_line(colour = "grey92"),
    panel.grid.minor  = element_blank()
  )

# PLOT 1: SR vs AI z-scores, faceted by trait, coloured by condition
  # Shows discriminant validity (or lack of) between SR and AI trait scores

# Reshape to long format for faceting

scatter_long <- map_dfr(traits, function(t) {
  df %>%
    transmute(
      Condition,
      Trait = t,
      SR_z  = .data[[paste0("SR_z_", t)]],
      AI_z  = .data[[paste0("AI_z_", t)]]
    )
})

# Calculate per-trait per-condition correlations for annotation

corr_labels <- scatter_long %>%
  group_by(Trait, Condition) %>%
  summarise(
    r   = cor(SR_z, AI_z, use = "complete.obs"),
    SR_z = 1.8,
    AI_z = ifelse(Condition == "Honest", -2.1, -2.6),  # stagger vertically
    .groups = "drop"
  ) %>%
  mutate(label = sprintf("r = %.2f", r))

plot1 <- ggplot(scatter_long, aes(x = SR_z, y = AI_z, colour = Condition)) +
  geom_hline(yintercept = 0, linetype = "dashed", colour = "grey70", linewidth = 0.4) +
  geom_vline(xintercept = 0, linetype = "dashed", colour = "grey70", linewidth = 0.4) +
  geom_point(alpha = 0.55, size = 1.8) +
  geom_smooth(method = "lm", se = TRUE, linewidth = 0.9, alpha = 0.15) +
  geom_text(data = corr_labels,
            aes(label = label), size = 3, show.legend = FALSE,
            fontface = "italic") +
  facet_wrap(~ Trait, nrow = 2) +
  scale_colour_manual(values = c("Honest" = "#4E79A7", "Job" = "#E15759"),
                      labels = c("Honest condition", "Job condition")) +
  labs(
    title    = "Figure 1. SR–AI Personality Score Agreement by Trait and Condition",
    subtitle = "Standardised (z-scored) self-report vs. AI scores. Shaded bands = 95% CI.",
    x        = "Self-Report z-score (IPIP-50)",
    y        = "AI z-score (Minej/BERT)",
    colour   = NULL
  ) +
  dissertation_theme

ggsave("plot1_h1_sr_ai_scatter.png", plot1,
       width = 10, height = 6.5, dpi = 300, bg = "white")
cat("Saved: plot1_h1_sr_ai_scatter.png\n")

# PLOT 2: Grouped bar chart — AI trait proportions by condition
  # Shows which traits the AI scores differently between honest and job conditions

bar_data <- df %>%
  select(Condition, all_of(paste0("AI_", traits))) %>%
  pivot_longer(-Condition,
               names_to  = "Trait",
               names_prefix = "AI_",
               values_to = "AI_proportion") %>%
  group_by(Condition, Trait) %>%
  summarise(
    Mean = mean(AI_proportion, na.rm = TRUE),
    SE   = sd(AI_proportion, na.rm = TRUE) / sqrt(n()),
    .groups = "drop"
  ) %>%
  mutate(Trait = factor(Trait, levels = traits))

plot2 <- ggplot(bar_data, aes(x = Trait, y = Mean, fill = Condition)) +
  geom_col(position = position_dodge(width = 0.65), width = 0.6, alpha = 0.9) +
  geom_errorbar(aes(ymin = Mean - SE, ymax = Mean + SE),
                position = position_dodge(width = 0.65),
                width = 0.2, linewidth = 0.6) +
  annotate("text", x = c(1, 3, 4, 5),
           y = c(0.215, 0.285, 0.175, 0.205),
           label = c("*", "**", "***", "**"),
           size = 5, colour = "grey20")+
  scale_fill_manual(values = c("Honest" = "#4E79A7", "Job" = "#E15759"),
                    labels = c("Honest condition", "Job condition")) +
  scale_y_continuous(labels = scales::percent_format(accuracy = 1),
                     expand = expansion(mult = c(0, 0.08))) +
  labs(
    title    = "Figure 2. BERT-Derived Trait Proportions by Condition",
    subtitle = "Mean trait proportion (± SE). Scores sum to 1.0 per participant.",
    x        = "Personality Trait",
    y        = "Mean AI Trait Proportion",
    fill     = NULL
  ) +
  dissertation_theme +
  theme(axis.text.x = element_text(angle = 20, hjust = 1))

ggsave("plot2_h2_ai_traits_bar.png", plot2,
       width = 8, height = 5.5, dpi = 300, bg = "white")
cat("Saved: plot2_h2_ai_traits_bar.png\n")

# PLOT 3: Radar / spider chart — AI trait profile by condition
  # Gives a clear view of the full personality profile shift between conditions

# fmsb requires a specific format: max row, min row, then data rows

radar_means <- df %>%
  group_by(Condition) %>%
  summarise(across(all_of(paste0("AI_", traits)), mean, na.rm = TRUE)) %>%
  column_to_rownames("Condition") %>%
  setNames(traits)

# Add max and min rows required by fmsb

radar_data <- as.data.frame(rbind(
  max = rep(0.30, 5),   # max (slightly above observed max ~0.275 for Conscientiousness)
  min = rep(0.13, 5),   # min (slightly below observed min ~0.14)
  radar_means
))
colnames(radar_data) <- traits

png("plot3_h2_radar.png", width = 1800, height = 1500, res = 300)
par(mar = c(1, 1, 2, 1))

radarchart(
  radar_data,
  axistype  = 1,
  pcol      = c("#4E79A7", "#E15759"),
  pfcol     = c(adjustcolor("#4E79A7", alpha.f = 0.25),
                adjustcolor("#E15759", alpha.f = 0.25)),
  plwd      = 2,
  cglcol    = "grey80",
  cglty     = 1,
  axislabcol = "grey50",
  caxislabels = seq(0.13, 0.30, length.out = 5) %>% round(2),
  vlcex     = 0.85,
  title     = "Figure 3. BERT Personality Profiles by Condition"
)

legend("bottomleft",
       legend  = c("Honest condition", "Job condition"),
       col     = c("#4E79A7", "#E15759"),
       lty     = 1, lwd = 2, bty = "n", cex = 0.85,
       fill    = c(adjustcolor("#4E79A7", alpha.f = 0.25),
                   adjustcolor("#E15759", alpha.f = 0.25)))
dev.off()
cat("Saved: plot3_h2_radar.png\n")

# PLOT 4: SR vs AI z-scores faceted by SES level
  # Visualises whether the SR–AI relationship changes across SES groups

ses_labels <- c(
  "1" = "Below 5\nGCSEs",
  "2" = "5+ GCSEs",
  "3" = "A-Level /\nEquiv.",
  "4" = "Bachelor's /\nEquiv.",
  "5" = "Postgraduate"
)

h3_long <- map_dfr(traits, function(t) {
  df %>%
    filter(!is.na(SES_numeric)) %>%
    transmute(
      SES_label = factor(ses_labels[as.character(SES_numeric)],
                         levels = ses_labels),
      Condition,
      Trait = t,
      SR_z  = .data[[paste0("SR_z_", t)]],
      AI_z  = .data[[paste0("AI_z_", t)]]
    )
})

# Per-SES per-trait correlation labels

ses_corr <- h3_long %>%
  group_by(Trait, SES_label) %>%
  summarise(
    r    = cor(SR_z, AI_z, use = "complete.obs"),
    n    = sum(!is.na(SR_z) & !is.na(AI_z)),
    SR_z = 1.6,
    AI_z = -2.2,
    .groups = "drop"
  ) %>%
  mutate(label = sprintf("r=%.2f\n(n=%d)", r, n))

plot4 <- ggplot(h3_long, aes(x = SR_z, y = AI_z, colour = Trait)) +
  geom_hline(yintercept = 0, linetype = "dashed",
             colour = "grey75", linewidth = 0.4) +
  geom_point(alpha = 0.5, size = 1.5) +
  geom_smooth(method = "lm", se = FALSE, linewidth = 0.8) +
  geom_text(data = ses_corr,
            aes(label = label), size = 2.4,
            colour = "grey30", show.legend = FALSE) +
  facet_grid(Trait ~ SES_label, switch = "y") +
  scale_colour_manual(values = trait_cols) +
  labs(
    title    = "Figure 4. SR–AI Relationship by Trait and SES Level",
    subtitle = "Each panel shows one trait × SES combination. Lines = OLS regression.",
    x        = "Self-Report z-score (IPIP-50)",
    y        = "AI z-score (BERT)",
    colour   = "Trait"
  ) +
  dissertation_theme +
  theme(
    legend.position = "none",
    strip.text.y    = element_text(angle = 0, hjust = 0),
    axis.text       = element_text(size = 7)
  )

ggsave("plot4_h3_ses_facet.png", plot4,
       width = 12, height = 9, dpi = 300, bg = "white")
cat("Saved: plot4_h3_ses_facet.png\n")

# PLOT 5: SR trait distributions by condition
  # Shows that SR profiles are similar across conditions — randomisation check

sr_long <- map_dfr(traits, function(t) {
  df %>% transmute(Condition, Trait = t,
                   SR = .data[[paste0("SR_", t)]])
}) %>%
  mutate(Trait = factor(Trait, levels = traits))

plot5 <- ggplot(sr_long, aes(x = SR, fill = Condition)) +
  geom_density(alpha = 0.45, colour = NA) +
  geom_vline(data = sr_long %>% group_by(Condition, Trait) %>%
               summarise(m = mean(SR), .groups = "drop"),
             aes(xintercept = m, colour = Condition),
             linetype = "dashed", linewidth = 0.7) +
  facet_wrap(~ Trait, nrow = 2, scales = "free_y") +
  scale_fill_manual(values  = c("Honest" = "#4E79A7", "Job" = "#E15759")) +
  scale_colour_manual(values = c("Honest" = "#4E79A7", "Job" = "#E15759")) +
  scale_x_continuous(limits = c(1, 5), breaks = 1:5) +
  labs(
    title    = "Figure 5. Self-Report Trait Distributions by Condition",
    subtitle = "Density curves with condition means (dashed lines). Scale: 1–5.",
    x        = "Mean IPIP-50 Score",
    y        = "Density",
    fill     = NULL, colour = NULL
  ) +
  dissertation_theme

ggsave("plot5_sr_distributions.png", plot5,
       width = 10, height = 6, dpi = 300, bg = "white")
cat("Saved: plot5_sr_distributions.png\n")

cat("\nAll plots saved. Required packages: tidyverse, patchwork, fmsb\n")
cat("Install with: install.packages(c('patchwork', 'fmsb'))\n")
